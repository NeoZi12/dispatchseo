# DispatchSEO - environment variables.
# Copy to .env.local for local dev; set the same keys in Vercel for production.

# --- Supabase (create a free project at supabase.com, then apply supabase/migrations/) ---
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# The Vercel Marketplace Supabase integration injects this as SUPABASE_SECRET_KEY
# instead - both names work (db.ts checks SUPABASE_SERVICE_ROLE_KEY first).

# --- MCP + cron auth (OPTIONAL overrides - the setup wizard replaces these) ---
# Fresh deploys generate both at /setup and store them in the database; most
# installs leave these empty. Setting one (e.g. `openssl rand -hex 24`)
# overrides the stored value - that's how pre-wizard installs keep working.
MCP_API_KEY=
CRON_SECRET=

# --- Backend URL (OPTIONAL override - normally auto-derived) ---
# Self-hosted deploys don't need this: the wizard captures this deploy's own
# URL at claim time and every connected repo's pipeline uses that automatically
# (falling back to Vercel's own VERCEL_PROJECT_PRODUCTION_URL if claimed before
# that column existed). Set APP_URL only to force a specific domain - e.g. you
# front the deploy with a custom domain the claim request never saw.
APP_URL=

# --- DataForSEO (optional - keyword volumes + SERP rank tracking) ---
# LOGIN is your account email; PASSWORD is the auto-generated API password from
# app.dataforseo.com/api-access (NOT your dashboard login password). Leave empty
# to run without paid SERP data; paid features skip gracefully.
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
# Encrypts per-project DataForSEO API passwords at rest (AES-256-GCM). Generate
# with `openssl rand -base64 32`. Use the SAME value in local dev and Vercel;
# rotating it makes already-stored passwords undecryptable. Not needed in the
# GitHub Actions pipeline (those workflows use their own DATAFORSEO_* secrets).
DATAFORSEO_ENC_KEY=

# --- Google Search Console (free - impressions/clicks/position stats) ---
# The full service-account JSON key, single line. Add the service account's
# email as a user on your Search Console property.
GSC_SERVICE_ACCOUNT_JSON=
# Your property, e.g. sc-domain:example.com (domain property) or https://example.com/ (URL prefix)
GSC_SITE_URL=

# --- Weekly opportunities cron seeds (comma-separated topics around your product) ---
SEED_KEYWORDS=your topic,another topic,a third topic

# --- Dashboard login (OPTIONAL override - the setup wizard replaces it) ---
# Fresh deploys choose the password at /setup (stored as a hash in the DB).
# Setting this env var overrides the stored one; it is how pre-wizard
# installs keep working. If you set it, make it strong - it is the only gate.
DASHBOARD_PASSWORD=

# --- Google OAuth "Connect Search Console" button (optional - cloud/demo) ---
# Self-hosters don't need these; the service-account path above is the normal
# route. Create an OAuth client (Web application) in Google Cloud Console with
# redirect URI https://<your-domain>/api/oauth/google/callback.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- One-tap PR merge (optional - buttons degrade to links without it) ---
# A GitHub personal access token (repo scope) that lets the dashboard's merge
# and re-run-validation buttons act directly instead of only linking out to
# the PR/Action on GitHub. Without it those buttons still show; they just open
# the GitHub page for you to click through instead of firing in one tap.
GH_MERGE_TOKEN=

# --- Cron failure emails (strongly recommended in auto mode - without them,
# failures only surface when you open the dashboard) ---
# Free key from resend.com. ALERT_EMAIL is where failure emails go (max one
# per job per 24h). Leave ALERT_EMAIL_FROM empty to use Resend's test sender;
# set it once you verify your own domain in Resend.
RESEND_API_KEY=
ALERT_EMAIL=
ALERT_EMAIL_FROM=

# --- Public landing page (cloud deployment only - leave unset when self-hosting) ---
# "true" serves the marketing landing page + cloud waitlist at /. Self-hosted
# installs leave this unset so / goes straight to the dashboard login.
LANDING_ENABLED=
